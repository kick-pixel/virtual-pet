# ====================================
# Pet AI Platform - Environment Variables
# ====================================

# Application Info
VITE_APP_TITLE=Pet AI Platform
VITE_APP_ENV=production

# API Configuration
VITE_APP_BASE_API=https://api.yoursite.com

# Splash Video (开机动画)
# 请将此URL替换为您的CDN地址
VITE_SPLASH_VIDEO_URL=https://cdn.example.com/splash/intro.mp4

# Web3 Configuration (Optional)
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id

# Feature Flags (Optional)
# VITE_ENABLE_SPLASH=true
# VITE_ENABLE_OAUTH=false
