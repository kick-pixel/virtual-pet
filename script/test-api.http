Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "provider": "ark",
  "model": "doubao-seedance-1-5-pro-251215",
  "prompt": "一辆地铁轰隆隆驶过，书页和女孩的头发飞扬，镜头开始环绕着女孩360度旋转，周围的背景从地铁站渐渐转变为一个中世纪的教堂，西式幻想风格的音乐渐入",
  "duration": 5,
  "ratio": "16:9",
  "generateAudio": true,
  "watermark": false
}

