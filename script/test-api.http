###############################################################################
# 2. AI视频生成测试接口 (/test/ai)
###############################################################################

### 2.1 快速测试 - 创建简单视频任务
POST {{baseUrl}}/test/ai/quickTest
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

### 2.2 创建视频生成任务（文本提示词）
POST {{baseUrl}}/test/ai/createTask
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "prompt": "A beautiful sunset over the ocean with waves",
  "model": "default",
  "duration": 5,
  "resolution": "720p",
  "aspectRatio": "16:9"
}

### 2.3 创建视频生成任务（图片+提示词）
POST {{baseUrl}}/test/ai/createTaskWithImage
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "prompt": "Add motion to this image",
  "imageUrl": "https://aidog.ffd8cb4a1f2ff512d2b986f96266ba0e.r2.cloudflarestorage.com/test/2026/02/08/29f5124bb4064e1e8e81ed5efbc33f96.jpg?X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Date=20260208T091305Z&X-Amz-SignedHeaders=host&X-Amz-Expires=3600&X-Amz-Credential=3cf920ef4e73c93bab0375a9a6f1f97b%2F20260208%2Fauto%2Fs3%2Faws4_request&X-Amz-Signature=7c1d7eff723ce3cc8bd61bfcdfc57efcad4a82a916ec3e9ddc863c025475c0a7",
