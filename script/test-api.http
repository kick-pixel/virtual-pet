###############################################################################
# PEI AI Platform - 测试接口集合
#
# 使用说明：
# 1. 在VS Code中安装REST Client扩展
# 2. 先执行登录接口获取token
# 3. 将token更新到@token变量
# 4. 按顺序测试各个接口
#
# 创建日期：2026-02-07
###############################################################################

# ============================================================================
# 全局变量配置
# ============================================================================
@baseUrl = http://localhost:8181
@token = Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJhZG1pbiIsImxvZ2luX3VzZXJfa2V5IjoiNDUxZjdlOWQtNjlmYi00NWQzLTllNzAtYTI5ODg0M2ZhNWNjIn0.ADr5OJ3c4HK83UpSzv1-hwQDy2CstDFT6FisBW1ccZUtZnZRQJ8ZtCdyH1ltBrMqZ86q5hadgKmMTZD3DuB-uw

@contentType = application/json

# ============================================================================
# AI 视频生成提供商切换说明
# ============================================================================
# 系统支持两个视频生成提供商，通过 "provider" 参数切换：
#
# 1. OpenAI Sora (provider: "openai")
#    - 模型：sora-2
#    - 参数：prompt, imageUrl, model, duration, resolution, aspectRatio
#
# 2. 火山引擎 Seedance (provider: "ark")
#    - 模型：doubao-seedance-1-5-pro-251215（推荐）, doubao-seedance-1-0-pro-250528 等
#    - 参数：prompt, imageUrl, model, duration, ratio, generateAudio, watermark,
#            endFrameImageUrl, referenceImageUrls
#    - 特色功能：音画同生、首尾帧生视频、多参考图生视频
#
# 如果不指定 provider，系统会使用第一个可用的提供商
# ============================================================================

###############################################################################
# 0. 系统接口 - 登录认证
###############################################################################

### 0.1 用户登录（获取Token）
POST {{baseUrl}}/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "admin123"
}

###############################################################################
# 1. 文件管理测试接口 (/test/file)
###############################################################################

### 1.1 测试存储服务健康检查
GET {{baseUrl}}/test/file/health
Authorization: Bearer {{token}}

### 1.2 测试文件上传（单文件）
# 注意：请修改为实际的图片文件路径
# 语法：< 后面跟文件的绝对路径或相对路径
POST {{baseUrl}}/test/file/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="test.mp4"
Content-Type: video/mp4

< E:/pet-web3/0de712b72d46eaeac48dcba60cb2042e.mp4
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="folder"

test
------WebKitFormBoundary7MA4YWxkTrZu0gW--

# 使用示例（需要修改为实际路径）：
# Windows: < C:/Users/YourName/Pictures/dog.jpg
# 相对路径: < ./test-images/dog.jpg

# {
#   "msg": "文件上传成功",
