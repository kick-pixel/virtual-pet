Authorization: Bearer {{token}}

### 3.4 手动触发区块链扫描（扫描所有网络）
POST {{baseUrl}}/test/web3/triggerScan
Authorization: Bearer {{token}}

### 3.5 手动触发区块链扫描（指定网络）
POST {{baseUrl}}/test/web3/triggerScan?networkId=1
Authorization: Bearer {{token}}

### 3.6 查询交易详情
GET {{baseUrl}}/test/web3/getTransaction?txHash=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
Authorization: Bearer {{token}}

### 3.7 获取待确认的交易列表
GET {{baseUrl}}/test/web3/getPendingTransactions
Authorization: Bearer {{token}}

### 3.8 更新待确认交易的确认数
POST {{baseUrl}}/test/web3/updatePendingTransactions
Authorization: Bearer {{token}}

### 3.9 获取所有启用的网络配置
GET {{baseUrl}}/test/web3/getEnabledNetworks
Authorization: Bearer {{token}}

### 3.10 获取指定网络的代币配置
GET {{baseUrl}}/test/web3/getTokensByNetwork/ethereum_sepolia
Authorization: Bearer {{token}}

###############################################################################
# 4. Web3管理接口 (/web3) - 生产环境接口
###############################################################################

### 4.1 查询区块链配置列表
GET {{baseUrl}}/web3/blockchain/list?pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### 4.2 查询区块链配置详情
GET {{baseUrl}}/web3/blockchain/1
Authorization: Bearer {{token}}

### 4.3 新增区块链配置
POST {{baseUrl}}/web3/blockchain
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "networkName": "Ethereum Sepolia",
  "networkType": "ethereum_sepolia",
  "chainId": 11155111,
  "rpcUrl": "https://sepolia.infura.io/v3/YOUR_PROJECT_ID",
  "explorerUrl": "https://sepolia.etherscan.io",
  "scanStartBlock": 0,
  "scanBatchSize": 100,
  "minConfirmations": 12,
  "status": "1",
  "remark": "以太坊Sepolia测试网"
}

### 4.4 修改区块链配置
PUT {{baseUrl}}/web3/blockchain
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "configId": 1,
  "networkName": "Ethereum Sepolia",
  "status": "1",
  "minConfirmations": 15
}

### 4.5 删除区块链配置
DELETE {{baseUrl}}/web3/blockchain/1
Authorization: Bearer {{token}}

### 4.6 测试区块链连接
GET {{baseUrl}}/web3/blockchain/testConnection/1
Authorization: Bearer {{token}}

### 4.7 查询代币配置列表
GET {{baseUrl}}/web3/token/list?pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### 4.8 新增代币配置
POST {{baseUrl}}/web3/token
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "networkType": "ethereum_sepolia",
  "tokenSymbol": "USDT",
  "tokenName": "Tether USD",
  "contractAddress": "0xdac17f958d2ee523a2206206994597c13d831ec7",
  "decimals": 6,
  "status": "1",
  "remark": "以太坊USDT"
}

### 4.9 查询交易记录列表
GET {{baseUrl}}/web3/transaction/list?pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### 4.10 根据交易哈希查询
GET {{baseUrl}}/web3/transaction/hash/0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
Authorization: Bearer {{token}}

### 4.11 查询待确认交易
GET {{baseUrl}}/web3/transaction/pending?pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### 4.12 手动触发扫描
POST {{baseUrl}}/web3/transaction/scan
Authorization: Bearer {{token}}

###############################################################################
# 5. 测试场景组合
###############################################################################

### 场景1：完整的文件上传测试流程
# 1. 健康检查 -> 2. 上传文件 -> 3. 查看文件信息 -> 4. 下载文件 -> 5. 删除文件

### 场景2：完整的AI视频生成流程（OpenAI）
# 1. 快速测试 -> 2. 创建任务 -> 3. 查询状态 -> 4. 同步状态 -> 5. 处理完成

### 场景2.5：完整的火山引擎视频生成流程
# 1. 文生视频 (2.5.1) -> 2. 查询状态 (2.4) -> 3. 同步状态 (2.6) -> 4. 处理完成 (2.7)
# 或：图生视频 (2.5.2) -> 音画同生 (2.5.3) -> 多参考图 (2.5.7)

### 场景3：完整的Web3扫描流程
# 1. 快速测试连接 -> 2. 获取启用网络 -> 3. 触发扫描 -> 4. 查询待确认交易 -> 5. 更新确认数

###############################################################################
# 附录：常用变量值
###############################################################################

# 网络类型示例：
# - ethereum_mainnet
# - ethereum_sepolia
# - bsc_mainnet
# - bsc_testnet

# 代币符号示例：
# - ETH
# - BNB
# - USDT

# AI 提供商：
# - openai: OpenAI Sora
# - ark: 火山引擎 Seedance

# 视频比例（ratio，火山引擎专用）：
# - 16:9: 横屏视频
# - 9:16: 竖屏视频
# - adaptive: 自适应（根据输入图片）

# 任务状态：
# - pending: 待处理
# - processing: 处理中
# - completed: 已完成
# - failed: 失败
# - cancelled: 已取消

# 交易状态：
# - pending: 待确认
# - confirmed: 已确认
# - failed: 失败

###############################################################################
# 注意事项
###############################################################################

# 1. 文件上传接口需要实际的文件，可以使用Postman或curl测试
# 2. AI接口配置：
#    - OpenAI: 需要配置 OPENAI_API_KEY 环境变量
#    - 火山引擎: 需要配置 ARK_API_KEY 环境变量（获取：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey）
# 3. 火山引擎模型选择：
#    - doubao-seedance-1-5-pro-251215: 最高品质，支持音画同生（推荐）
#    - doubao-seedance-1-0-pro-250528: 标准版，平衡品质和速度
#    - doubao-seedance-1-0-pro-fast-251015: 快速版，注重速度
#    - doubao-seedance-1-0-lite-t2v-250428: 轻量文生视频
#    - doubao-seedance-1-0-lite-i2v-250428: 轻量图生视频，支持多参考图
# 4. Web3接口需要配置RPC URL和Infura Project ID
# 5. 所有接口都需要先登录获取token
# 6. 测试接口仅用于开发测试，生产环境应禁用或限制访问

###############################################################################
# END
###############################################################################
