<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysBlockchainConfigMapper">

    <resultMap type="SysBlockchainConfig" id="SysBlockchainConfigResult">
        <id     property="configId"          column="config_id"           />
        <result property="networkType"       column="network_type"        />
        <result property="networkName"       column="network_name"        />
        <result property="chainId"           column="chain_id"            />
        <result property="rpcUrl"            column="rpc_url"             />
        <result property="explorerUrl"       column="explorer_url"        />
        <result property="walletAddress"     column="wallet_address"      />
        <result property="scanStartBlock"    column="scan_start_block"    />
        <result property="scanCurrentBlock"  column="scan_current_block"  />
        <result property="scanBatchSize"     column="scan_batch_size"     />
        <result property="minConfirmations"  column="min_confirmations"   />
        <result property="status"            column="status"              />
        <result property="remark"            column="remark"              />
        <result property="createBy"          column="create_by"           />
        <result property="createTime"        column="create_time"         />
        <result property="updateBy"          column="update_by"           />
        <result property="updateTime"        column="update_time"         />
    </resultMap>

    <sql id="selectBlockchainConfigVo">
        select config_id, network_type, network_name, chain_id, rpc_url, explorer_url,
               wallet_address, scan_start_block, scan_current_block, scan_batch_size,
               min_confirmations, status, remark, create_by, create_time, update_by, update_time
        from sys_blockchain_config
    </sql>

    <select id="selectBlockchainConfigById" parameterType="Long" resultMap="SysBlockchainConfigResult">
        <include refid="selectBlockchainConfigVo"/>
        where config_id = #{configId}
    </select>

    <select id="selectBlockchainConfigByNetworkType" parameterType="String" resultMap="SysBlockchainConfigResult">
        <include refid="selectBlockchainConfigVo"/>
        where network_type = #{networkType}
    </select>

    <select id="selectEnabledBlockchainConfigByChainId" parameterType="Long" resultMap="SysBlockchainConfigResult">
        <include refid="selectBlockchainConfigVo"/>
        where chain_id = #{chainId} and status = '0'
        limit 1
    </select>

    <select id="selectBlockchainConfigList" parameterType="SysBlockchainConfig" resultMap="SysBlockchainConfigResult">
        <include refid="selectBlockchainConfigVo"/>
        <where>
            <if test="networkType != null and networkType != ''">
                AND network_type = #{networkType}
            </if>
            <if test="networkName != null and networkName != ''">
                AND network_name like concat('%', #{networkName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by config_id
    </select>

    <select id="selectEnabledBlockchainConfigList" resultMap="SysBlockchainConfigResult">
        <include refid="selectBlockchainConfigVo"/>
        where status = '0'
        order by config_id
    </select>

    <insert id="insertBlockchainConfig" parameterType="SysBlockchainConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into sys_blockchain_config (
            <if test="networkType != null and networkType != ''">network_type,</if>
            <if test="networkName != null and networkName != ''">network_name,</if>
            <if test="chainId != null">chain_id,</if>
            <if test="rpcUrl != null and rpcUrl != ''">rpc_url,</if>
            <if test="explorerUrl != null and explorerUrl != ''">explorer_url,</if>
            <if test="walletAddress != null and walletAddress != ''">wallet_address,</if>
            <if test="scanStartBlock != null">scan_start_block,</if>
            <if test="scanCurrentBlock != null">scan_current_block,</if>
            <if test="scanBatchSize != null">scan_batch_size,</if>
            <if test="minConfirmations != null">min_confirmations,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        ) values (
            <if test="networkType != null and networkType != ''">#{networkType},</if>
            <if test="networkName != null and networkName != ''">#{networkName},</if>
            <if test="chainId != null">#{chainId},</if>
            <if test="rpcUrl != null and rpcUrl != ''">#{rpcUrl},</if>
            <if test="explorerUrl != null and explorerUrl != ''">#{explorerUrl},</if>
            <if test="walletAddress != null and walletAddress != ''">#{walletAddress},</if>
            <if test="scanStartBlock != null">#{scanStartBlock},</if>
            <if test="scanCurrentBlock != null">#{scanCurrentBlock},</if>
            <if test="scanBatchSize != null">#{scanBatchSize},</if>
            <if test="minConfirmations != null">#{minConfirmations},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateBlockchainConfig" parameterType="SysBlockchainConfig">
        update sys_blockchain_config
        <set>
            <if test="networkType != null and networkType != ''">network_type = #{networkType},</if>
            <if test="networkName != null and networkName != ''">network_name = #{networkName},</if>
            <if test="chainId != null">chain_id = #{chainId},</if>
            <if test="rpcUrl != null and rpcUrl != ''">rpc_url = #{rpcUrl},</if>
            <if test="explorerUrl != null">explorer_url = #{explorerUrl},</if>
            <if test="walletAddress != null and walletAddress != ''">wallet_address = #{walletAddress},</if>
            <if test="scanStartBlock != null">scan_start_block = #{scanStartBlock},</if>
            <if test="scanCurrentBlock != null">scan_current_block = #{scanCurrentBlock},</if>
            <if test="scanBatchSize != null">scan_batch_size = #{scanBatchSize},</if>
            <if test="minConfirmations != null">min_confirmations = #{minConfirmations},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where config_id = #{configId}
    </update>

    <update id="updateScanCurrentBlock">
        update sys_blockchain_config
        set scan_current_block = #{blockNumber}, update_time = sysdate()
        where config_id = #{configId}
    </update>

    <delete id="deleteBlockchainConfigById" parameterType="Long">
        delete from sys_blockchain_config where config_id = #{configId}
    </delete>

    <delete id="deleteBlockchainConfigByIds" parameterType="Long">
        delete from sys_blockchain_config where config_id in
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

</mapper>
