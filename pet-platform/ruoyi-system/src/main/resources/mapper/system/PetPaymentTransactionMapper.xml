<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.PetPaymentTransactionMapper">

    <resultMap type="PetPaymentTransaction" id="PetPaymentTransactionResult">
        <id     property="txId"            column="tx_id"            />
        <result property="txHash"          column="tx_hash"          />
        <result property="networkType"     column="network_type"     />
        <result property="networkName"     column="network_name"     />
        <result property="explorerUrl"     column="explorer_url"     />
        <result property="blockNumber"     column="block_number"     />
        <result property="blockTimestamp"  column="block_timestamp"  />
        <result property="fromAddress"     column="from_address"     />
        <result property="toAddress"       column="to_address"       />
        <result property="tokenSymbol"     column="token_symbol"     />
        <result property="tokenAddress"    column="token_address"    />
        <result property="amount"          column="amount"           />
        <result property="amountDisplay"   column="amount_display"   />
        <result property="gasPrice"        column="gas_price"        />
        <result property="gasUsed"         column="gas_used"         />
        <result property="txFee"           column="tx_fee"           />
        <result property="status"          column="status"           />
        <result property="confirmations"   column="confirmations"    />
        <result property="userId"          column="user_id"          />
        <result property="businessType"    column="business_type"    />
        <result property="businessId"      column="business_id"      />
        <result property="isProcessed"     column="is_processed"     />
        <result property="processTime"     column="process_time"     />
        <result property="remark"          column="remark"           />
        <result property="createTime"      column="create_time"      />
        <result property="updateTime"      column="update_time"      />
    </resultMap>

    <sql id="selectTransactionVo">
        select t.tx_id, t.tx_hash, t.network_type, t.block_number, t.block_timestamp, t.from_address, t.to_address,
               t.token_symbol, t.token_address, t.amount, t.amount_display, t.gas_price, t.gas_used, t.tx_fee,
               t.status, t.confirmations, t.user_id, t.business_type, t.business_id, t.is_processed, t.process_time,
               t.remark, t.create_time, t.update_time,
               b.network_name, b.explorer_url
        from pet_payment_transaction t
        left join sys_blockchain_config b on t.network_type = b.network_type
    </sql>

    <select id="selectTransactionById" parameterType="Long" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        where tx_id = #{txId}
    </select>

    <select id="selectTransactionByHash" parameterType="String" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        where tx_hash = #{txHash}
    </select>

    <select id="selectTransactionList" parameterType="PetPaymentTransaction" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        <where>
            <if test="txHash != null and txHash != ''">
                AND t.tx_hash = #{txHash}
            </if>
            <if test="networkType != null and networkType != ''">
                AND t.network_type = #{networkType}
            </if>
            <if test="fromAddress != null and fromAddress != ''">
                AND t.from_address = #{fromAddress}
            </if>
            <if test="toAddress != null and toAddress != ''">
                AND t.to_address = #{toAddress}
            </if>
            <if test="tokenSymbol != null and tokenSymbol != ''">
                AND t.token_symbol = #{tokenSymbol}
            </if>
            <if test="status != null and status != ''">
                AND t.status = #{status}
            </if>
            <if test="userId != null">
                AND t.user_id = #{userId}
            </if>
            <if test="businessType != null and businessType != ''">
                AND t.business_type = #{businessType}
            </if>
            <if test="isProcessed != null and isProcessed != ''">
                AND t.is_processed = #{isProcessed}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(t.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(t.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
        order by t.create_time desc
    </select>

    <select id="selectPendingTransactions" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        where t.status = 'pending'
        order by t.create_time
    </select>

    <select id="selectUnprocessedConfirmedTransactions" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        where t.status = 'confirmed' and t.is_processed = '0'
        order by t.create_time
    </select>

    <select id="selectTransactionByUserId" parameterType="Long" resultMap="PetPaymentTransactionResult">
        <include refid="selectTransactionVo"/>
        where t.user_id = #{userId}
        order by t.create_time desc
    </select>

    <select id="checkTxHashExists" parameterType="String" resultType="int">
        select count(1) from pet_payment_transaction where tx_hash = #{txHash}
    </select>

    <insert id="insertTransaction" parameterType="PetPaymentTransaction" useGeneratedKeys="true" keyProperty="txId">
        insert into pet_payment_transaction (
            <if test="txHash != null and txHash != ''">tx_hash,</if>
            <if test="networkType != null and networkType != ''">network_type,</if>
            <if test="blockNumber != null">block_number,</if>
            <if test="blockTimestamp != null">block_timestamp,</if>
            <if test="fromAddress != null and fromAddress != ''">from_address,</if>
            <if test="toAddress != null and toAddress != ''">to_address,</if>
            <if test="tokenSymbol != null and tokenSymbol != ''">token_symbol,</if>
            <if test="tokenAddress != null">token_address,</if>
            <if test="amount != null">amount,</if>
            <if test="amountDisplay != null and amountDisplay != ''">amount_display,</if>
            <if test="gasPrice != null">gas_price,</if>
            <if test="gasUsed != null">gas_used,</if>
            <if test="txFee != null">tx_fee,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="confirmations != null">confirmations,</if>
            <if test="userId != null">user_id,</if>
            <if test="businessType != null and businessType != ''">business_type,</if>
            <if test="businessId != null">business_id,</if>
            <if test="isProcessed != null and isProcessed != ''">is_processed,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        ) values (
            <if test="txHash != null and txHash != ''">#{txHash},</if>
            <if test="networkType != null and networkType != ''">#{networkType},</if>
            <if test="blockNumber != null">#{blockNumber},</if>
            <if test="blockTimestamp != null">#{blockTimestamp},</if>
            <if test="fromAddress != null and fromAddress != ''">#{fromAddress},</if>
            <if test="toAddress != null and toAddress != ''">#{toAddress},</if>
            <if test="tokenSymbol != null and tokenSymbol != ''">#{tokenSymbol},</if>
            <if test="tokenAddress != null">#{tokenAddress},</if>
            <if test="amount != null">#{amount},</if>
            <if test="amountDisplay != null and amountDisplay != ''">#{amountDisplay},</if>
            <if test="gasPrice != null">#{gasPrice},</if>
            <if test="gasUsed != null">#{gasUsed},</if>
            <if test="txFee != null">#{txFee},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="confirmations != null">#{confirmations},</if>
            <if test="userId != null">#{userId},</if>
            <if test="businessType != null and businessType != ''">#{businessType},</if>
            <if test="businessId != null">#{businessId},</if>
            <if test="isProcessed != null and isProcessed != ''">#{isProcessed},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateTransaction" parameterType="PetPaymentTransaction">
        update pet_payment_transaction
        <set>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="confirmations != null">confirmations = #{confirmations},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="businessType != null">business_type = #{businessType},</if>
            <if test="businessId != null">business_id = #{businessId},</if>
            <if test="isProcessed != null and isProcessed != ''">is_processed = #{isProcessed},</if>
            <if test="processTime != null">process_time = #{processTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where tx_id = #{txId}
    </update>

    <update id="updateTransactionStatus">
        update pet_payment_transaction
        set status = #{status}, confirmations = #{confirmations}, update_time = sysdate()
        where tx_id = #{txId}
    </update>

    <update id="markTransactionProcessed" parameterType="Long">
        update pet_payment_transaction
        set is_processed = '1', process_time = sysdate(), update_time = sysdate()
        where tx_id = #{txId}
    </update>

    <delete id="deleteTransactionById" parameterType="Long">
        delete from pet_payment_transaction where tx_id = #{txId}
    </delete>

    <delete id="deleteTransactionByIds" parameterType="Long">
        delete from pet_payment_transaction where tx_id in
        <foreach item="txId" collection="array" open="(" separator="," close=")">
            #{txId}
        </foreach>
    </delete>

</mapper>
