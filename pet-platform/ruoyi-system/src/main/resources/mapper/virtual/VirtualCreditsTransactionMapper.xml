<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.VirtualCreditsTransactionMapper">

    <resultMap type="VirtualCreditsTransaction" id="VirtualCreditsTransactionResult">
        <id     property="txId"            column="tx_id"             />
        <result property="userId"          column="user_id"           />
        <result property="txType"          column="tx_type"           />
        <result property="amount"          column="amount"            />
        <result property="direction"       column="direction"         />
        <result property="balanceBefore"   column="balance_before"    />
        <result property="balanceAfter"    column="balance_after"     />
        <result property="businessType"    column="business_type"     />
        <result property="businessId"      column="business_id"       />
        <result property="relatedTxId"     column="related_tx_id"     />
        <result property="description"     column="description"       />
        <result property="operator"        column="operator"          />
        <result property="ipAddress"       column="ip_address"        />
        <result property="createTime"      column="create_time"       />
    </resultMap>

    <sql id="selectVo">
        select tx_id, user_id, tx_type, amount, direction, balance_before, balance_after,
               business_type, business_id, related_tx_id, description, operator, ip_address, create_time
        from virtual_credits_transaction
    </sql>

    <select id="selectByTxId" parameterType="Long" resultMap="VirtualCreditsTransactionResult">
        <include refid="selectVo"/> where tx_id = #{txId}
    </select>

    <select id="selectByUserId" parameterType="Long" resultMap="VirtualCreditsTransactionResult">
        <include refid="selectVo"/> where user_id = #{userId} order by create_time desc
    </select>

    <select id="selectVirtualCreditsTransactionList" parameterType="VirtualCreditsTransaction" resultMap="VirtualCreditsTransactionResult">
        <include refid="selectVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="txType != null and txType != ''">AND tx_type = #{txType}</if>
            <if test="businessType != null and businessType != ''">AND business_type = #{businessType}</if>
            <if test="businessId != null">AND business_id = #{businessId}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertVirtualCreditsTransaction" parameterType="VirtualCreditsTransaction" useGeneratedKeys="true" keyProperty="txId">
        insert into virtual_credits_transaction (user_id, tx_type, amount, direction, balance_before, balance_after,
            business_type, business_id, related_tx_id, description, operator, ip_address, create_time)
        values (#{userId}, #{txType}, #{amount}, #{direction}, #{balanceBefore}, #{balanceAfter},
            #{businessType}, #{businessId}, #{relatedTxId}, #{description}, #{operator}, #{ipAddress}, sysdate())
    </insert>

    <!-- 管理后台积分流水查询（支持 direction、时间范围过滤） -->
    <select id="selectAdminCreditsTransactionList" parameterType="VirtualCreditsTransaction"
            resultMap="VirtualCreditsTransactionResult">
        <include refid="selectVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="txType != null and txType != ''">AND tx_type = #{txType}</if>
            <if test="direction != null">AND direction = #{direction}</if>
            <if test="params != null and params.beginTime != null and params.beginTime != ''">
                AND create_time &gt;= #{params.beginTime}
            </if>
            <if test="params != null and params.endTime != null and params.endTime != ''">
                AND create_time &lt;= #{params.endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

</mapper>
