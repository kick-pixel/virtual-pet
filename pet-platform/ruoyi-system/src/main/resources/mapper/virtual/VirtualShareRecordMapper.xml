<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.VirtualShareRecordMapper">

    <resultMap type="VirtualShareRecord" id="VirtualShareRecordResult">
        <id     property="shareId"        column="share_id"        />
        <result property="userId"         column="user_id"         />
        <result property="taskId"         column="task_id"         />
        <result property="platform"       column="platform"        />
        <result property="shareUrl"       column="share_url"       />
        <result property="shareContent"   column="share_content"   />
        <result property="status"         column="status"          />
        <result property="rewardCredits"  column="reward_credits"  />
        <result property="rewardTxId"     column="reward_tx_id"    />
        <result property="errorMessage"   column="error_message"   />
        <result property="sharedAt"       column="shared_at"       />
        <result property="createTime"     column="create_time"     />
    </resultMap>

    <sql id="selectVo">
        select share_id, user_id, task_id, platform, share_url, share_content, status,
               reward_credits, reward_tx_id, error_message, shared_at, create_time
        from virtual_share_record
    </sql>

    <select id="selectByShareId" parameterType="Long" resultMap="VirtualShareRecordResult">
        <include refid="selectVo"/> where share_id = #{shareId}
    </select>

    <select id="selectByUserId" parameterType="Long" resultMap="VirtualShareRecordResult">
        <include refid="selectVo"/> where user_id = #{userId} order by create_time desc
    </select>

    <select id="selectVirtualShareRecordList" parameterType="VirtualShareRecord" resultMap="VirtualShareRecordResult">
        <include refid="selectVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="taskId != null">AND task_id = #{taskId}</if>
            <if test="platform != null and platform != ''">AND platform = #{platform}</if>
            <if test="status != null and status != ''">AND status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertVirtualShareRecord" parameterType="VirtualShareRecord" useGeneratedKeys="true" keyProperty="shareId">
        insert into virtual_share_record (user_id, task_id, platform, share_url, share_content,
            status, reward_credits, create_time)
        values (#{userId}, #{taskId}, #{platform}, #{shareUrl}, #{shareContent},
            #{status}, #{rewardCredits}, sysdate())
    </insert>

    <update id="updateVirtualShareRecord" parameterType="VirtualShareRecord">
        update virtual_share_record
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="rewardCredits != null">reward_credits = #{rewardCredits},</if>
            <if test="rewardTxId != null">reward_tx_id = #{rewardTxId},</if>
            <if test="errorMessage != null">error_message = #{errorMessage},</if>
            <if test="sharedAt != null">shared_at = #{sharedAt},</if>
        </set>
        where share_id = #{shareId}
    </update>

</mapper>
