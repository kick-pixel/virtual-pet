<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.VirtualUserFavoriteMapper">

    <resultMap type="VirtualUserFavorite" id="VirtualUserFavoriteResult">
        <id     property="id"          column="id"          />
        <result property="userId"      column="user_id"     />
        <result property="targetType"  column="target_type" />
        <result property="targetId"    column="target_id"   />
        <result property="createTime"  column="create_time" />
    </resultMap>

    <sql id="selectVo">
        select id, user_id, target_type, target_id, create_time from virtual_user_favorite
    </sql>

    <select id="selectById" parameterType="Long" resultMap="VirtualUserFavoriteResult">
        <include refid="selectVo"/> where id = #{id}
    </select>

    <select id="selectByUserAndTarget" resultMap="VirtualUserFavoriteResult">
        <include refid="selectVo"/>
        where user_id = #{userId} and target_type = #{targetType} and target_id = #{targetId}
    </select>

    <select id="selectByUserId" parameterType="Long" resultMap="VirtualUserFavoriteResult">
        <include refid="selectVo"/> where user_id = #{userId} order by create_time desc
    </select>

    <select id="selectVirtualUserFavoriteList" parameterType="VirtualUserFavorite" resultMap="VirtualUserFavoriteResult">
        <include refid="selectVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="targetType != null and targetType != ''">AND target_type = #{targetType}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertVirtualUserFavorite" parameterType="VirtualUserFavorite" useGeneratedKeys="true" keyProperty="id">
        insert into virtual_user_favorite (user_id, target_type, target_id, create_time)
        values (#{userId}, #{targetType}, #{targetId}, sysdate())
    </insert>

    <delete id="deleteById" parameterType="Long">
        delete from virtual_user_favorite where id = #{id}
    </delete>

    <delete id="deleteByUserAndTarget">
        delete from virtual_user_favorite
        where user_id = #{userId} and target_type = #{targetType} and target_id = #{targetId}
    </delete>

</mapper>
