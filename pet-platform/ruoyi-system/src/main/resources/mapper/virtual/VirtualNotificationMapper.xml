<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.VirtualNotificationMapper">

    <resultMap type="VirtualNotification" id="VirtualNotificationResult">
        <id     property="notificationId"  column="notification_id"  />
        <result property="userId"          column="user_id"          />
        <result property="type"            column="type"             />
        <result property="title"           column="title"            />
        <result property="content"         column="content"          />
        <result property="extraData"       column="extra_data"       />
        <result property="isRead"          column="is_read"          />
        <result property="readAt"          column="read_at"          />
        <result property="channel"         column="channel"          />
        <result property="channelSent"     column="channel_sent"     />
        <result property="createTime"      column="create_time"      />
    </resultMap>

    <sql id="selectVo">
        select notification_id, user_id, type, title, content, extra_data, is_read,
               read_at, channel, channel_sent, create_time
        from virtual_notification
    </sql>

    <select id="selectByNotificationId" parameterType="Long" resultMap="VirtualNotificationResult">
        <include refid="selectVo"/> where notification_id = #{notificationId}
    </select>

    <select id="selectByUserId" parameterType="Long" resultMap="VirtualNotificationResult">
        <include refid="selectVo"/> where user_id = #{userId} order by create_time desc
    </select>

    <select id="selectUnreadByUserId" parameterType="Long" resultMap="VirtualNotificationResult">
        <include refid="selectVo"/> where user_id = #{userId} and is_read = 0 order by create_time desc
    </select>

    <select id="selectVirtualNotificationList" parameterType="VirtualNotification" resultMap="VirtualNotificationResult">
        <include refid="selectVo"/>
        <where>
            <if test="userId != null">AND user_id = #{userId}</if>
            <if test="type != null and type != ''">AND type = #{type}</if>
            <if test="isRead != null">AND is_read = #{isRead}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectUnreadCount" parameterType="Long" resultType="int">
        select count(*) from virtual_notification where user_id = #{userId} and is_read = 0
    </select>

    <insert id="insertVirtualNotification" parameterType="VirtualNotification" useGeneratedKeys="true" keyProperty="notificationId">
        insert into virtual_notification (user_id, type, title, content, extra_data, channel, create_time)
        values (#{userId}, #{type}, #{title}, #{content}, #{extraData}, #{channel}, sysdate())
    </insert>

    <update id="updateVirtualNotification" parameterType="VirtualNotification">
        update virtual_notification
        <set>
            <if test="isRead != null">is_read = #{isRead},</if>
            <if test="readAt != null">read_at = #{readAt},</if>
            <if test="channelSent != null">channel_sent = #{channelSent},</if>
        </set>
        where notification_id = #{notificationId}
    </update>

    <update id="markAsRead" parameterType="Long">
        update virtual_notification set is_read = 1, read_at = sysdate()
        where notification_id = #{notificationId}
    </update>

    <update id="markAllAsRead" parameterType="Long">
        update virtual_notification set is_read = 1, read_at = sysdate()
        where user_id = #{userId} and is_read = 0
    </update>

</mapper>
